# Server Configuration
PORT=3000
NODE_ENV=development

# Shopify Configuration
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here
SHOPIFY_APP_URL=https://localhost:3000

# Optional: Database Configuration (for future use)
# DATABASE_URL=mongodb://localhost:27017/shopify-labels
# DATABASE_NAME=shopify-labels

# Optional: Session Configuration
SESSION_SECRET=your_session_secret_here

# Optional: Logging
LOG_LEVEL=debug

# Optional: CORS Configuration
CORS_ORIGIN=http://localhost:3000,https://admin.shopify.com
